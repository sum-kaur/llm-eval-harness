# Copy to .env and fill in your keys.
# The harness reads these automatically via python-dotenv.

# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (if using --provider openai)
OPENAI_API_KEY=sk-...

# Optional: OpenAI-compatible endpoint
# OPENAI_COMPATIBLE_API_KEY=...
# Pass --base-url when running: llm-eval run suite.yaml --provider openai_compatible --base-url http://localhost:11434/v1
